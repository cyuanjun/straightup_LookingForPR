# Behaviour
TZ=Asia/Singapore
CONFIRMATION_WINDOW_MIN=15
CHECK_BACK_OFFSET_MIN=12
PATTERN_WINDOW_DAYS=42
DEMO_MODE_FAST_FORWARD=false

# Set to true during development to skip ElevenLabs (bot sends/receives text instead of voice)
VOICE_DISABLED=false

GP_NAME_DEFAULT=Dr Tan
SG_EMERGENCY_NUMBER=995
AUDIO_CACHE_DIR=./cache/audio
LOG_LEVEL=INFO

# Demo seeds (fill after creating the Telegram group)
DEMO_FAMILY_ID=
# Negative int; super-groups start with -100. Leave blank if unused.
DEMO_GROUP_CHAT_ID=
