BOT_USERNAME=
WEBHOOK_URL=
WEBHOOK_SECRET_TOKEN=

# LLM
OPENAI_API_KEY=

# Voice
ELEVENLABS_API_KEY=
AUNTY_MAY_VOICE_ID=

# Data
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=briefings

# Direct Postgres Session DSN (port 5432). NOT the PgBouncer pooler (6543).
